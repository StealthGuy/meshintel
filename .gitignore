# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# ============================================================
# Backend — Cache e dati generati
# ============================================================
# I dump dei dati Meshtastic sono grandi e vengono generati
# ogni giorno dalla pipeline CI. Non vanno in versione control.
backend/cache/*.json
# Ma teniamo la cartella vuota
!backend/cache/.gitkeep

# Cartella di output dei dati statici generati per il frontend
frontend/public/data/*.json
!frontend/public/data/.gitkeep

# ============================================================
# Node.js / Frontend
# ============================================================
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

